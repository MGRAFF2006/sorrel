--- /dev/null
+++ b/README.md
@@ -0,0 +1,15 @@
+# Sorrel Web
+
+Static landing page for Sorrel Core and Sorrel Hub.
+
+## Local preview
+
+Open `index.html` directly in a browser, or serve the directory with any static file server:
+
+```bash
+python3 -m http.server 8080
+```
+
+## Purpose
+
+This repo is intentionally small. It gives agents and designers a shared starting point for the public website while the product architecture is still being shaped in the parent report repository.
diff --git a/index.html b/index.html
new file mode 100644
index 0000000..69eab7f
--- /dev/null
+++ b/index.html
@@ -0,0 +1,131 @@
+<!doctype html>
+<html lang="en">
+  <head>
+    <meta charset="utf-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1">
+    <title>Sorrel - Agent-native version control</title>
+    <meta
+      name="description"
+      content="Sorrel Core and Sorrel Hub are an agent-native version-control and collaboration system for modern software work."
+    >
+    <link rel="stylesheet" href="styles.css">
+  </head>
+  <body>
+    <header class="hero">
+      <nav class="nav" aria-label="Primary navigation">
+        <a class="brand" href="#top" aria-label="Sorrel home">
+          <span class="brand-mark">S</span>
+          <span>Sorrel</span>
+        </a>
+        <div class="nav-links">
+          <a href="#core">Core</a>
+          <a href="#hub">Hub</a>
+          <a href="#roadmap">Roadmap</a>
+        </div>
+      </nav>
+
+      <section id="top" class="hero-grid">
+        <div>
+          <p class="eyebrow">Agent-native version control</p>
+          <h1>Version control for humans, agents, and the cloud.</h1>
+          <p class="lead">
+            Sorrel is a new architecture for source control and collaboration:
+            change-first, Git-compatible, filesystem-optional, secret-aware, and
+            built for many parallel AI agents.
+          </p>
+          <div class="actions">
+            <a class="button primary" href="#core">Explore Sorrel Core</a>
+            <a class="button secondary" href="#hub">See Sorrel Hub</a>
+          </div>
+        </div>
+        <aside class="card terminal" aria-label="Sorrel command examples">
+          <div class="terminal-bar">
+            <span></span><span></span><span></span>
+          </div>
+          <pre><code>sorrel init --git-colocated
+sorrel lane create agent/fix-auth
+sorrel slice create --entry packages/auth/src/index.ts
+sorrel workflow run test --runner local-docker</code></pre>
+        </aside>
+      </section>
+    </header>
+
+    <main>
+      <section class="section split" id="core">
+        <div>
+          <p class="eyebrow">Sorrel Core</p>
+          <h2>The protocol and runtime.</h2>
+        </div>
+        <div class="feature-grid">
+          <article class="card">
+            <h3>Change-first model</h3>
+            <p>
+              Changes, stacks, lanes, conflicts, and resolutions are first-class
+              objects instead of branch side effects.
+            </p>
+          </article>
+          <article class="card">
+            <h3>Runs anywhere</h3>
+            <p>
+              Native filesystem, bare server mode, browser storage, object
+              storage, SQLite, and fully in-memory workspaces.
+            </p>
+          </article>
+          <article class="card">
+            <h3>Git bridge</h3>
+            <p>
+              Import, export, mirror, and coexist with Git so teams can migrate
+              without a flag day.
+            </p>
+          </article>
+        </div>
+      </section>
+
+      <section class="section split dark" id="hub">
+        <div>
+          <p class="eyebrow">Sorrel Hub</p>
+          <h2>The collaboration layer.</h2>
+        </div>
+        <div class="feature-grid">
+          <article class="card">
+            <h3>Private work</h3>
+            <p>
+              Hide or redact work-in-progress proposals through real policy,
+              not just UI filtering.
+            </p>
+          </article>
+          <article class="card">
+            <h3>Slices</h3>
+            <p>
+              Extract a shareable subproject from an entrypoint while preserving
+              links, permissions, and provenance.
+            </p>
+          </article>
+          <article class="card">
+            <h3>Portable runners</h3>
+            <p>
+              Run workflows locally, over SSH, in Docker, on Kubernetes, or on
+              user-owned remote infrastructure.
+            </p>
+          </article>
+        </div>
+      </section>
+
+      <section class="section roadmap" id="roadmap">
+        <p class="eyebrow">Roadmap</p>
+        <h2>Designed as independent modules.</h2>
+        <ol class="steps">
+          <li><strong>Core engine:</strong> objects, changes, snapshots, undo, and in-memory storage.</li>
+          <li><strong>Git bridge:</strong> colocated repos, import/export, and remote mirroring.</li>
+          <li><strong>Lanes and slices:</strong> parallel workstreams and shareable subprojects.</li>
+          <li><strong>Workflows:</strong> content-addressed jobs and capability-based runners.</li>
+          <li><strong>Hub:</strong> proposals, review, issues, merge queue, secrets, and policies.</li>
+        </ol>
+      </section>
+    </main>
+
+    <footer class="footer">
+      <p>Sorrel is being specified as an open, modular system.</p>
+    </footer>
+  </body>
+</html>
diff --git a/styles.css b/styles.css
new file mode 100644
index 0000000..ea35bee
--- /dev/null
+++ b/styles.css
@@ -0,0 +1,284 @@
+:root {
+  --bg: #111812;
+  --bg-soft: #182219;
+  --panel: #f7f1e8;
+  --panel-strong: #fffaf1;
+  --text: #162016;
+  --muted: #5d6b5d;
+  --cream: #fff8ec;
+  --sorrel: #819545;
+  --sorrel-dark: #536528;
+  --line: rgba(22, 32, 22, 0.12);
+  --shadow: 0 24px 80px rgba(0, 0, 0, 0.22);
+}
+
+* {
+  box-sizing: border-box;
+}
+
+html {
+  scroll-behavior: smooth;
+}
+
+body {
+  margin: 0;
+  color: var(--text);
+  background: var(--panel);
+  font-family:
+    Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
+    sans-serif;
+}
+
+a {
+  color: inherit;
+  text-decoration: none;
+}
+
+.hero {
+  min-height: 760px;
+  color: var(--cream);
+  background:
+    radial-gradient(circle at 80% 20%, rgba(129, 149, 69, 0.42), transparent 32rem),
+    linear-gradient(135deg, var(--bg), var(--bg-soft));
+  padding: 24px;
+}
+
+.nav {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  max-width: 1160px;
+  margin: 0 auto;
+  padding: 12px 0;
+}
+
+.brand,
+.nav-links {
+  display: flex;
+  align-items: center;
+  gap: 14px;
+}
+
+.brand {
+  font-weight: 800;
+  letter-spacing: -0.03em;
+}
+
+.brand-mark {
+  display: grid;
+  width: 36px;
+  height: 36px;
+  place-items: center;
+  color: var(--bg);
+  background: var(--sorrel);
+  border-radius: 12px;
+}
+
+.nav-links {
+  color: rgba(255, 248, 236, 0.76);
+  font-size: 0.95rem;
+}
+
+.nav-links a:hover {
+  color: var(--cream);
+}
+
+.hero-grid {
+  display: grid;
+  grid-template-columns: minmax(0, 1.08fr) minmax(320px, 0.92fr);
+  gap: 48px;
+  align-items: center;
+  max-width: 1160px;
+  margin: 120px auto 0;
+}
+
+.eyebrow {
+  margin: 0 0 14px;
+  color: var(--sorrel);
+  font-size: 0.78rem;
+  font-weight: 800;
+  letter-spacing: 0.16em;
+  text-transform: uppercase;
+}
+
+h1,
+h2,
+h3,
+p {
+  margin-top: 0;
+}
+
+h1 {
+  max-width: 780px;
+  margin-bottom: 22px;
+  font-size: clamp(3rem, 8vw, 6.8rem);
+  line-height: 0.92;
+  letter-spacing: -0.08em;
+}
+
+h2 {
+  margin-bottom: 24px;
+  font-size: clamp(2.2rem, 5vw, 4.4rem);
+  line-height: 0.98;
+  letter-spacing: -0.06em;
+}
+
+h3 {
+  margin-bottom: 12px;
+  font-size: 1.15rem;
+}
+
+.lead {
+  max-width: 660px;
+  color: rgba(255, 248, 236, 0.78);
+  font-size: clamp(1.08rem, 2vw, 1.28rem);
+  line-height: 1.7;
+}
+
+.actions {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 14px;
+  margin-top: 34px;
+}
+
+.button {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  min-height: 48px;
+  padding: 0 20px;
+  border: 1px solid rgba(255, 248, 236, 0.22);
+  border-radius: 999px;
+  font-weight: 750;
+}
+
+.button.primary {
+  color: var(--bg);
+  background: var(--sorrel);
+  border-color: var(--sorrel);
+}
+
+.button.secondary {
